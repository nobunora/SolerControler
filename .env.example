# ===== Runtime =====
TIMEZONE=Asia/Tokyo
DRY_RUN=true
HEADLESS=true
BROWSER_TIMEOUT_MS=45000
ARTIFACTS_DIR=artifacts
HISTORY_CSV_PATH=artifacts/history.csv
HISTORY_SQLITE_ENABLED=true
HISTORY_SQLITE_PATH=artifacts/history.db
LOCAL_DEV_MODE=true
LOCAL_MONITOR_CSV_PATH=sample_data/monitoring_sample.csv
# 空なら実際に予報サイトへアクセス。固定値で試す場合は例: 4.5
LOCAL_FORECAST_HOURS_OVERRIDE=
# ローカル疑似更新で使う現在値（任意）
LOCAL_CURRENT_CHARGE_LIMIT_TEXT=70

# ===== Forecast site =====
# Open-Meteo: 東京都府中市 (35.67452, 139.48216) の日次日照時間
# `sunshine_duration` は秒なので、FORECAST_VALUE_DIVISOR=3600 で時間に変換
FORECAST_URL=https://api.open-meteo.com/v1/forecast?latitude=35.67452&longitude=139.48216&daily=sunshine_duration&timezone=Asia%2FTokyo&forecast_days=3
# JSON表示のため pre を読む
FORECAST_READY_SELECTOR=pre
FORECAST_HOURS_SELECTOR=pre
# 2番目の値(=翌日)を抽出: "sunshine_duration":[today,tomorrow,...]
FORECAST_VALUE_REGEX="sunshine_duration":\[[0-9.]+,([0-9.]+)
FORECAST_VALUE_DIVISOR=3600

# ===== Monitoring service login =====
MONITOR_LOGIN_URL=https://example.com/login
MONITOR_CSV_PAGE_URL=https://example.com/operation/csv
MONITOR_SETTINGS_URL=https://example.com/battery/settings
MONITOR_USERNAME=your_username
MONITOR_PASSWORD=your_password

LOGIN_USERNAME_SELECTOR=input[name='username']
LOGIN_PASSWORD_SELECTOR=input[name='password']
LOGIN_SUBMIT_SELECTOR=button[type='submit']
# ログイン後に確実に表示される要素（任意）
LOGIN_SUCCESS_SELECTOR=

# ===== CSV download =====
CSV_PRE_CLICK_SELECTOR=
CSV_DOWNLOAD_SELECTOR=button#download-csv

# ===== Battery settings =====
SETTINGS_CHARGE_LIMIT_SELECTOR=input[name='chargeLimit']
SETTINGS_MODE_SELECTOR=select[name='mode']
SETTINGS_SUBMIT_SELECTOR=button[type='submit']
SETTINGS_SUCCESS_SELECTOR=
SETTINGS_CURRENT_CHARGE_LIMIT_SELECTOR=input[name='chargeLimit']

# ===== CSV parsing =====
CSV_TIMESTAMP_COLUMN=
CSV_SOC_COLUMN=SOC
CSV_CHARGE_POWER_COLUMN=ChargePower
CSV_DISCHARGE_POWER_COLUMN=DischargePower

# ===== Decision thresholds =====
FORECAST_HIGH_HOURS=6.0
FORECAST_LOW_HOURS=2.0
LOW_SOC_THRESHOLD=30.0
HIGH_SOC_THRESHOLD=80.0

CHARGE_LIMIT_HIGH=95
CHARGE_LIMIT_MID=70
CHARGE_LIMIT_LOW=40

MODE_HIGH_SUN=charge-priority
MODE_MID_SUN=balanced
MODE_LOW_SUN=economy
# グリーンモードは最大50%まで。50%以上必要時に強制充電へ切替える
GREEN_MODE_MAX_CHARGE_PERCENT=50
MODE_FORCE_CHARGE=forced-charge

# ===== KP-NET dedicated flow =====
KP_BASE_URL=https://ctrl.kp-net.com/settingcontrol
# 本番では https を強制（false はローカル検証専用）
KP_ENFORCE_HTTPS=true
# 接続許可ホスト（カンマ区切り）
KP_ALLOWED_HOSTS=ctrl.kp-net.com
KP_MONITOR_USERNAME=
KP_MONITOR_PASSWORD=
# true の場合、KP_MONITOR_USERNAME/PASSWORD 未設定時に HAR から抽出
KP_USE_HAR_CREDENTIALS=false
KP_HAR_PATH=C:\path\to\ctrl.kp-net.com.har
KP_WORKFLOW_MODE=all
# forced-only: 強制充電のみ / forced-then-green: 強制充電後にグリーンモード
KP_SETTINGS_SEQUENCE=forced-only
# auto: 時刻/シーケンスで自動, forced: 強制充電のみ, green: グリーンモードのみ
KP_FORCE_SETTINGS_PROFILE=auto
# true: night_charge_plan.json から強制充電設定を自動算出
KP_DYNAMIC_FORCED_PROFILE=true
# true: 現在時刻で設定対象を自動選択（夜間=強制充電 / 日中=グリーン）
KP_DYNAMIC_MODE_SWITCH_BY_TIME=true
# 運用条件ファイル（固定条件/変動条件/優先順位）
KP_OPERATION_CONDITIONS_PATH=config/operation_conditions.json
# 03:10微調整ジョブ（Cloud Run slot=03）向け
# - 予報更新判定: 初回値に対して sun/temp が閾値以上で変化したら更新扱い
# - 更新がなければ ADJUST03_WAIT_SECONDS 待って再取得（最大 ADJUST03_MAX_ATTEMPTS 回）
ADJUST03_MAX_ATTEMPTS=3
ADJUST03_WAIT_SECONDS=600
ADJUST03_SUN_EPSILON_H=0.05
ADJUST03_TEMP_EPSILON_C=0.2
KP_NIGHT_PLAN_PATH=artifacts/night_charge_plan.json
# 計画CSVから夜間実測値が得られない場合のフォールバック(kW)
KP_DEFAULT_CHARGE_POWER_KW=1.8
# グリーンモードで扱える充電量上限(%)
KP_GREEN_MODE_MAX_CHARGE_PERCENT=50
# 夜間帯(放電させたくない帯)と日中放電帯
KP_NIGHT_CHARGE_WINDOW_START=23:00
KP_NIGHT_CHARGE_WINDOW_END=07:00
KP_DAY_DISCHARGE_WINDOW_START=07:00
KP_DAY_DISCHARGE_WINDOW_END=23:00
KP_CSV_TARGET_MONTHS=2026-04,2026-05
KP_DOWNLOAD_LATEST_MONTH=true
KP_CSV_OUTPUT_FORMAT=太陽光発電＋蓄電池
KP_CSV_AGGR_TYPE=30分データ
KP_TIMEOUT_SEC=60
# 翌朝の目標SOC計算に使う予備残量(%)
NIGHT_RESERVE_SOC_PERCENT=0
# 消費電力量予測モデル（45日未満は履歴平均にフォールバック）
CONSUMPTION_MODEL_MIN_TRAINING_DAYS=45
CONSUMPTION_MODEL_FALLBACK_WINDOW_DAYS=14
# ローカル検証用の翌日予報上書き（通常は未設定）
FORECAST_WEATHER_CODE_OVERRIDE=
FORECAST_PRECIPITATION_SUM_MM_OVERRIDE=
FORECAST_PRECIPITATION_PROBABILITY_MEAN_OVERRIDE=
FORECAST_SHORTWAVE_RADIATION_SUM_MJ_M2_OVERRIDE=
# 東・南・西など複数面PVをhourly GTIで予測する
PV_ARRAY_FORECAST_ENABLED=true
PV_ARRAY_CONFIG_PATH=config/pv_arrays.json
PV_ARRAY_CALIBRATION_LOOKBACK_DAYS=45
PV_ARRAY_CALIBRATION_MIN_DAYS=3
PV_ARRAY_CALIBRATION_MIN_FACTOR=0.2
PV_ARRAY_CALIBRATION_MAX_FACTOR=5.0
# 曇り/雨の過大・過小予測を抑える天候別補正
PV_ARRAY_WEATHER_CALIBRATION_ENABLED=true
PV_ARRAY_WEATHER_CALIBRATION_MIN_DAYS=2
PV_ARRAY_WEATHER_ADJUSTMENT_MIN_RATIO=0.7
PV_ARRAY_WEATHER_ADJUSTMENT_MAX_RATIO=1.3
# cloudy/rain 向けの弱い回帰補正（sun_hours と降水量）
PV_ARRAY_WEATHER_REGRESSION_ENABLED=true
PV_ARRAY_WEATHER_REGRESSION_MIN_DAYS=7
PV_ARRAY_WEATHER_REGRESSION_BLEND=0.1
PV_ARRAY_WEATHER_REGRESSION_RIDGE=0.01
# 10:00-16:00の負荷推定。空なら 6/13 相当。
PV_MIDDAY_LOAD_FRACTION=

# ===== DB / Storage sync =====
DAY_RATE_YEN_PER_KWH=31
# flat: 固定単価 / night8_tiered: おトクなナイト8の昼夜+段階制
COST_TARIFF_MODE=night8_tiered
NIGHT8_DAY_START_HHMM=07:00
NIGHT8_DAY_END_HHMM=23:00
# 昼間使用電力量の段階閾値（月次）
NIGHT8_DAY_TIER1_UPPER_KWH=90
NIGHT8_DAY_TIER2_UPPER_KWH=230
# おトクなナイト8の電力量単価（円/kWh）
NIGHT8_DAY_RATE_TIER1_YEN=31.80
NIGHT8_DAY_RATE_TIER2_YEN=39.10
NIGHT8_DAY_RATE_TIER3_YEN=43.62
NIGHT8_NIGHT_RATE_YEN=28.85
DATA_DB_PATH=artifacts/solar_monitor.db
# sqlite / postgres / firestore
DATA_BACKEND=firestore
# true: DBをCloud Storageと同期（現在は非推奨。既定OFF）
DATA_DB_SYNC_ENABLED=false
# true: DBへの永続書き込みは23時スロットのみ
DATA_DB_WRITE_ONLY_23=true
# 例: gs://your-us-bucket/solar-monitor/solar_monitor.db
DATA_GCS_DB_URI=
# ダッシュボード集計締め日。14なら「前月15日〜当月14日」を当月分として集計
DASHBOARD_AGGREGATION_CLOSE_DAY=14
# 週次差分バックアップ（既定: 土曜日=5 に実行）
DATA_WEEKLY_BACKUP_ENABLED=true
DATA_WEEKLY_BACKUP_WEEKDAY=5
DATA_WEEKLY_BACKUP_DIR=artifacts/backups/weekly

# ===== PostgreSQL (DATA_BACKEND=postgres の時に使用) =====
PGHOST=
PGPORT=5432
PGDATABASE=solar_ops
PGUSER=solar_app
PGPASSWORD=
PGSSLMODE=prefer

# ===== Firestore (DATA_BACKEND=firestore の時に使用) =====
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=(default)
